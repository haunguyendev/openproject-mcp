{
  "mcpServers": {
    "openproject": {
      "command": "uv",
      "args": [
        "run",
        "--script",
        "${CLAUDE_PLUGIN_ROOT}/server/server.py"
      ],
      "env": {
        "OPENPROJECT_URL": "https://manage.promete.ai",
        "OPENPROJECT_API_KEY": "<dán-API-key-của-bạn-vào-đây>",
        "OPENPROJECT_TIMEOUT_SECONDS": "30"
      }
    }
  }
}
